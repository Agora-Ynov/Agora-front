{
  "name": "agora-front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.js",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint src --ext .ts,.html",
    "lint:fix": "eslint src --ext .ts,.html --fix",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.html\"",
    "openapi:fetch": "curl -sS -o openapi/agora-openapi.json \"http://127.0.0.1:${BACKEND_PORT:-8082}/v3/api-docs\" && node scripts/normalize-openapi-tags.mjs",
    "openapi:import-from-back-tests": "sh -c 'cd \"${AGORA_BACK_DIR:-../Agora-back}\" && ./mvnw -q test -Dtest=OpenApiExportTest -Dagora.export.openapi=true && cp target/agora-openapi-export.json \"${AGORA_FRONT_DIR:-../Agora-front}/openapi/agora-openapi.json\"' && node scripts/normalize-openapi-tags.mjs",
    "openapi:sync": "npm run openapi:import-from-back-tests && npm run openapi:generate",
    "openapi:generate": "npx @openapitools/openapi-generator-cli generate -i openapi/agora-openapi.json -g typescript-angular -o src/app/core/api --additional-properties=providedIn=root,ngVersion=17"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular-eslint/builder": "^17.5.3",
    "@angular-eslint/eslint-plugin": "^17.5.3",
    "@angular-eslint/eslint-plugin-template": "^17.5.3",
    "@angular-eslint/template-parser": "^17.5.3",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "^17.3.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@types/jasmine": "~5.1.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "jasmine-core": "~5.1.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^14.6.2",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.4.2"
  }
}
